FROM node:20-alpine

# Still need these for some native dependencies (like bcrypt)
RUN apk add --no-cache python3 make g++

WORKDIR /app

COPY package*.json ./

# Install all dependencies
RUN npm install

COPY . .

# Convert TypeScript to JavaScript (this creates a /dist folder)
RUN npm run build

# Render uses 10000 by default, but this is mainly for documentation
EXPOSE 10000

# Use 'node' directly. DO NOT use nodemon or ts-node in production.
CMD ["npm", "start"]